{
  "cli": {
    "version": ">= 15.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "lowroute.com",
        "EXPO_PUBLIC_REVENUECAT_API_KEY_IOS": "appl_vUClFQiwQlmwtPgOecsJlLHLkCe",
        "EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID": "goog_eKXoEPJwstIexnWLjkvjGefpYqB"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "lowroute.com",
        "EXPO_PUBLIC_REVENUECAT_API_KEY_IOS": "appl_vUClFQiwQlmwtPgOecsJlLHLkCe",
        "EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID": "goog_eKXoEPJwstIexnWLjkvjGefpYqB"
